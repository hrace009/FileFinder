<Window x:Class="FileFinder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FileFinder.ViewModels"
        xmlns:models="clr-namespace:FileFinder.Models"
        mc:Ignorable="d"
        Title="FileFinder — Pencarian File"
        Icon="Icon.png"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding SearchCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ═══ Title Bar ═══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="#1565C0" Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="FileFinder" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Cari file di folder, shared folder, atau mapped drive"
                                   FontSize="11" Foreground="#BBDEFB"/>
                    </StackPanel>
                    <TextBlock Text="© 2026 By Harris Yogasara (mk.harris.y@pertamina.com)"
                               FontSize="10" Foreground="#90CAF9" FontStyle="Italic"
                               VerticalAlignment="Center" Margin="20,0,0,0"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#90CAF9" FontSize="11"
                           Text="F5 = Cari  |  Esc = Batal"/>
            </DockPanel>
        </Border>

        <!-- ═══ Status Bar ════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="#ECEFF1" BorderBrush="#CFD8DC" BorderThickness="0,1,0,0"
                Padding="10,5">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SummaryText}"
                           FontWeight="SemiBold" FontSize="12"
                           Foreground="#1565C0"
                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                <!-- Spinner — visible only while searching -->
                <Canvas Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"
                        Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="StatusSpinner" CenterX="9" CenterY="9"/>
                    </Canvas.RenderTransform>
                    <Ellipse Width="16" Height="16" Canvas.Left="1" Canvas.Top="1"
                             Stroke="#1565C0" StrokeThickness="2.5"
                             StrokeDashArray="4 7"/>
                    <Canvas.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="StatusSpinner"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360"
                                        Duration="0:0:0.75"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Canvas.Triggers>
                </Canvas>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12" Foreground="#546E7A"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ═══ Full-Width Progress Strip (below title, above content) ══════════════ -->
        <ProgressBar DockPanel.Dock="Top"
                     Value="{Binding ProgressValue}"
                     Maximum="{Binding ProgressMax}"
                     IsIndeterminate="{Binding IsIndeterminate}"
                     Height="6"
                     Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}"/>

        <!-- ═══ Main Content ══════════════════════════════════════════════════ -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Input Panel ─────────────────────────────────────── -->
            <DockPanel Grid.Column="0">
                <GroupBox DockPanel.Dock="Top">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋  Daftar Nama File"/>
                            <Border Background="#1565C0" CornerRadius="8" Padding="6,1" Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold"
                                           Text="{Binding InputLineCount, StringFormat='{}{0} baris'}"/>
                            </Border>
                        </StackPanel>
                    </GroupBox.Header>
                    <DockPanel>
                        <!-- Buttons -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="&#x1F4C2; Import TXT/CSV"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ImportCommand}"
                                        ToolTip="Import daftar nama dari file TXT atau CSV"/>
                                <Button Content="&#x1F5C1; Dari Folder"
                                        Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ImportFromFolderCommand}"
                                        ToolTip="Gunakan nama file dalam suatu folder sebagai daftar pencarian"/>
                                <Button Content="&#x1F5D1; Hapus"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding ClearInputCommand}"
                                        ToolTip="Hapus semua nama"/>
                            </StackPanel>
                            <CheckBox Content="Rekursif (termasuk semua subfolder)"
                                      IsChecked="{Binding ImportFolderRecursive}"
                                      Margin="2,5,0,0" FontSize="11" Foreground="#546E7A"
                                      ToolTip="Jika dicentang, 'Dari Folder' akan menyertakan file dari semua subfolder"/>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="Satu nama per baris. Mendukung wildcard (*.pdf)"
                                   FontSize="10" Foreground="#90A4AE"
                                   Margin="0,4,0,0"/>
                        <!-- Text area -->
                        <TextBox x:Name="InputTextBox"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 BorderBrush="#B0BEC5"
                                 Padding="6"
                                 MinHeight="200"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Masukkan nama file, satu per baris"/>
                    </DockPanel>
                </GroupBox>
            </DockPanel>

            <!-- ── Splitter ──────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#CFD8DC" Cursor="SizeWE"/>

            <!-- ── Middle: Config Panel ──────────────────────────────────── -->
            <DockPanel Grid.Column="2">
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Search Paths -->
                        <GroupBox Header="📁  Lokasi Pencarian">
                            <StackPanel>
                                <TextBlock Text="Folder, shared folder (\\server\share), atau mapped drive (Z:\):"
                                           FontSize="10" Foreground="#607D8B" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                <!-- Path input row -->
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right"
                                            Content="Browse"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding BrowseFolderCommand}"
                                            Padding="8,4" Margin="4,0,0,0"/>
                                    <Button DockPanel.Dock="Right"
                                            Content="+"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding AddPathCommand}"
                                            Padding="8,4" Margin="4,0,0,0"
                                            ToolTip="Tambah path ke daftar"/>
                                    <TextBox Text="{Binding NewPathText, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="12"
                                             Padding="4"
                                             BorderBrush="#B0BEC5"
                                             ToolTip="Ketik path lalu klik + atau tekan Enter">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding AddPathCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </DockPanel>

                                <!-- Path list -->
                                <ListBox ItemsSource="{Binding SearchPaths}"
                                         SelectedItem="{Binding SelectedPath}"
                                         MinHeight="80" MaxHeight="140"
                                         FontSize="11"
                                         BorderBrush="#B0BEC5"
                                         ToolTip="Klik untuk memilih, lalu klik Hapus untuk menghapus">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" ToolTip="{Binding}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Content="🗑 Hapus Path Terpilih"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding RemovePathCommand}"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Search Type -->
                        <GroupBox Header="🔎  Tipe Pencarian">
                            <StackPanel>
                                <RadioButton Content="Exact — Nama persis sama"
                                             IsChecked="{Binding SelectedSearchType, Converter={StaticResource EnumToBool}, ConverterParameter=Exact}"
                                             Margin="0,2" FontSize="12"/>
                                <RadioButton Content="Contains — Nama mengandung kata kunci"
                                             IsChecked="{Binding SelectedSearchType, Converter={StaticResource EnumToBool}, ConverterParameter=Contains}"
                                             Margin="0,2" FontSize="12"/>
                                <RadioButton Content="Wildcard — Pola (*,?), contoh: report_*.pdf"
                                             IsChecked="{Binding SelectedSearchType, Converter={StaticResource EnumToBool}, ConverterParameter=Wildcard}"
                                             Margin="0,2" FontSize="12"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Options -->
                        <GroupBox Header="⚙  Opsi">
                            <StackPanel>
                                <CheckBox Content="Rekursif (cari semua subfolder)"
                                          IsChecked="{Binding IsRecursive}"
                                          Margin="0,2" FontSize="12"/>
                                <CheckBox Content="Case-Sensitive"
                                          IsChecked="{Binding IsCaseSensitive}"
                                          Margin="0,2" FontSize="12"/>
                                <TextBlock Text="Filter ekstensi (kosong = semua):"
                                           FontSize="11" Foreground="#607D8B" Margin="0,6,0,2"/>
                                <TextBox Text="{Binding ExtensionFilter, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="4" BorderBrush="#B0BEC5"
                                         ToolTip="Contoh: .pdf .docx .xlsx — dipisah spasi atau koma"/>
                                <TextBlock Text="Contoh: .pdf .docx .xlsx"
                                           FontSize="10" Foreground="#90A4AE" Margin="0,2"/>
                                <TextBlock Text="Filter nama folder (kosong = semua folder):"
                                           FontSize="11" Foreground="#607D8B" Margin="0,6,0,2"/>
                                <TextBox Text="{Binding FolderFilter, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="4" BorderBrush="#B0BEC5"
                                         AcceptsReturn="True"
                                         MinHeight="52" MaxHeight="100"
                                         VerticalScrollBarVisibility="Auto"
                                         IsEnabled="{Binding IsNotSearching}"
                                         ToolTip="Nama folder yang dicari, satu per baris atau dipisah koma. Contoh: Archive, 2024"/>
                                <TextBlock Text="Contoh: Archive, 2024, Reports"
                                           FontSize="10" Foreground="#90A4AE" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Center">
                            <Button Content="🔍  Cari (F5)"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SearchCommand}"
                                    FontSize="14" Padding="16,8"/>
                            <Button Content="✕  Batal"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding CancelCommand}"
                                    FontSize="14" Padding="14,8"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- ── Splitter ──────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="#CFD8DC" Cursor="SizeWE"/>

            <!-- ── Right: Results Panel ──────────────────────────────────── -->
            <DockPanel Grid.Column="4">
                <!-- Top toolbar -->
                <Border DockPanel.Dock="Top"
                        Background="#E3F2FD" BorderBrush="#BBDEFB" BorderThickness="0,0,0,1"
                        Padding="6,4">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="📊 Export CSV"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ExportCsvCommand}"
                                    ToolTip="Export hasil ke file CSV (dibuka di Excel)"/>
                            <Button Content="🗑 Hapus Hasil"
                                    Style="{StaticResource DangerButton}"
                                    Command="{Binding ClearResultsCommand}"
                                    ToolTip="Hapus semua hasil"/>
                        </StackPanel>
                        <TextBlock Text="Hasil Pencarian"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#1565C0"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedResult}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F5F5F5"
                          BorderBrush="#CFD8DC"
                          FontSize="12"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background"
                                    Value="{Binding Status, Converter={StaticResource StatusToBg}}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                    <Setter Property="Foreground" Value="#0D47A1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="📂 Buka di Explorer"
                                      Command="{Binding PlacementTarget.DataContext.OpenInExplorerCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="📋 Copy Full Path"
                                      Command="{Binding PlacementTarget.DataContext.CopyFullPathCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="📄 Copy Nama File"
                                      Command="{Binding PlacementTarget.DataContext.CopyFileNameCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="40" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nama Input" Binding="{Binding InputName}" Width="170"/>
                        <DataGridTextColumn Header="File Ditemukan" Binding="{Binding FoundFileName}" Width="170"/>
                        <DataGridTextColumn Header="Full Path" Binding="{Binding FullPath}" Width="*"/>
                        <DataGridTextColumn Header="Ukuran" Binding="{Binding FileSizeDisplay}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Padding" Value="0,0,6,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Tgl Modifikasi" Binding="{Binding ModifiedDateDisplay}" Width="130"/>
                        <DataGridTemplateColumn Header="Status" Width="130" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusDisplay}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToFg}}"
                                               Padding="4,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
